# ─── Database ────────────────────────────────────────────────────────────────
# Absolute or relative (from repo root) path to the SQLite file.
# Defaults to <repo-root>/data/catalog.db when omitted.
DATABASE_PATH=./data/catalog.db

# ─── MCP Server ──────────────────────────────────────────────────────────────
MCP_PORT=3001

# ─── Admin API ───────────────────────────────────────────────────────────────
ADMIN_PORT=3000

# JWT secret used to sign admin session tokens.
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# JWT expiry for admin sessions (e.g. 1d, 8h, 30m)
JWT_EXPIRES_IN=1d

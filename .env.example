# ─── Data directory ──────────────────────────────────────────────────────────
# Where SQLite files and uploads are stored.
# Defaults to <repo-root>/_data/ when omitted.
#
# Structure created automatically:
#   _data/catalog.db         — registry (users, settings, stores list)
#   _data/stores/{slug}.db   — one catalog DB per store
#   _data/uploads/           — product image uploads
#
# DATA_DIR=/absolute/path/to/_data

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Gateway ──────────────────────────────────────────────────────────────────
# URL of the Prompt Commerce gateway — used to look up store details by key.
GATEWAY_URL=http://localhost:3003

# ─── Seller public URL ────────────────────────────────────────────────────────
# The publicly reachable base URL of THIS seller server.
# Used to build absolute image URLs when syncing products to the gateway so
# that the Telegram bot (and any other consumer) can display product photos.
# For local dev this defaults to http://localhost:<PORT> automatically.
# In production set this to your actual domain, e.g. https://shop.example.com
# SELLER_PUBLIC_URL=https://shop.example.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate a unique secret before first run — the server will refuse
# to start if this is missing or left as a placeholder (< 32 chars or known weak).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_EXPIRES_IN=1d

# ─── Default admin credentials (created on first startup) ────────────────────
# IMPORTANT: Change the password after your first login via Settings!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

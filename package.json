{
  "name": "@prompt-commerce/mcp-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "svelte-kit sync",
    "dev": "vite dev",
    "dev:server": "tsx watch server.ts",
    "prebuild": "svelte-kit sync",
    "build": "vite build",
    "start": "node --import tsx/esm server.ts",
    "start:prod": "NODE_ENV=production node --env-file=.env build/index.js",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "db:migrate": "tsx src/mcp/db/migrate.ts",
    "db:reset": "tsx src/mcp/db/migrate.ts --reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.5",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "svelte": "^5.54.0",
    "vite": "^6.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "bits-ui": "^2.16.3",
    "lucide-svelte": "^0.577.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
